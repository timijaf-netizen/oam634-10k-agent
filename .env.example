# Copy these into your Vercel project's Environment Variables (Settings → Environment Variables).
# Do NOT commit your real key to GitHub.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — which Claude model to use. Defaults to claude-sonnet-4-6 if unset.
#   claude-haiku-4-5-20251001  -> cheapest (~3x cheaper than Sonnet)
#   claude-sonnet-4-6          -> recommended balance of quality and cost
#   claude-opus-4-8            -> highest quality, most expensive
CLAUDE_MODEL=claude-sonnet-4-6
